---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Тарифы"
    title="Звёздные цены для каждого пути"
    subtitle="Выберите идеальный план, который соответствует вашим космическим целям."
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    title="Наши тарифы"
    subtitle="Выберите подходящий план для ваших целей"
    prices={[
      {
        title: 'Бесплатно',
        subtitle: 'Идеально для хобби и индивидуального использования.',
        price: 0,
        period: 'в месяц',
        items: [
          {
            description: 'Домен NewMode',
          },
          {
            description: 'Значок NewMode',
          },
          {
            description: '10 Участников',
          },
          {
            description: '5 Пространств',
          },
        ],
        callToAction: {
          text: 'Начать бесплатно',
          href: '#',
        },
      },
      {
        title: 'Про',
        subtitle: 'Для создателей и стартапов, масштабирующих продукты.',
        price: 49,
        period: 'в месяц',
        items: [
          {
            description: 'Безлимитные участники',
          },
          {
            description: 'Собственный домен',
          },
          {
            description: '20 Пространств',
          },
          {
            description: '25 ГБ хранилища',
          },
          {
            description: '5 Соавторов',
          },
          {
            description: '2 Локализации',
          },
        ],
        callToAction: {
          text: 'Начать за $49',
          href: '#',
          variant: 'primary',
        },
        hasRibbon: true,
        ribbonTitle: 'Популярный',
      },
      {
        title: 'Бизнес',
        subtitle: 'Для команд, которым нужно больше возможностей.',
        price: 99,
        period: 'в месяц',
        items: [
          {
            description: 'Безлимитные участники',
          },
          {
            description: 'Собственный домен',
          },
          {
            description: '30 Пространств',
          },
          {
            description: '10 Соавторов',
          },
          {
            description: '3 Локализации',
          },
          {
            description: 'SEO оптимизация',
          },
        ],
        callToAction: {
          text: 'Начать за $99',
          href: '#',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Возможности тарифов"
    subtitle="Узнайте преимущества выбора наших планов"
    columns={2}
    items={[
      {
        title: 'Многоуровневые тарифные планы',
        description: 'Выбирайте из ряда тарифных планов, разработанных для разных бюджетов и требований.',
        icon: 'tabler:stairs',
      },
      {
        title: 'Прозрачное ценообразование',
        description: 'Четкое отображение деталей цен для каждого плана, без скрытых затрат и неожиданных платежей.',
        icon: 'tabler:flip-vertical',
      },
      {
        title: 'Безопасные способы оплаты',
        description: 'Безопасные платежные шлюзы для защиты вашей финансовой информации во время транзакций.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Мгновенный доступ',
        description: `Немедленный доступ к функциям выбранного вами плана после подписки.`,
        icon: 'tabler:accessible',
      },
      {
        title: 'Ценность обновления',
        description: 'Переходите на тарифные планы более высокого уровня, чтобы разблокировать больше функций и преимуществ.',
        icon: 'tabler:chevrons-up',
      },
      {
        title: 'Поддержка 24/7',
        description: 'Ответы на вопросы через чат, электронную почту или телефон ежедневно.',
        icon: 'tabler:headset',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Путь от выбора плана до творчества"
    tagline="упрощенный процесс"
    isReversed={true}
    items={[
      {
        title: 'Изучите планы',
        icon: 'tabler:number-1',
      },
      {
        title: 'Выберите подходящий план',
        icon: 'tabler:number-2',
      },
      {
        title: 'Зарегистрируйтесь / Войдите',
        icon: 'tabler:number-3',
      },
      {
        title: 'Проверьте заказ',
        icon: 'tabler:number-4',
      },
      {
        title: 'Введите платежные данные',
        icon: 'tabler:number-5',
      },
      {
        title: 'Подтверждение',
        icon: 'tabler:number-6',
      },
      {
        title: 'Начните использовать',
        icon: 'tabler:number-7',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1536816579748-4ecb3f03d72a?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=987&q=80',
      alt: 'Steps image',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Часто задаваемые вопросы по ценам"
    subtitle="Выбор правильного плана важен, и мы готовы ответить на ваши вопросы."
    columns={1}
    items={[
      {
        title: 'Включают ли планы поддержку клиентов?',
        description:
          'Конечно, все планы включают доступ к нашей специальной службе поддержки клиентов.',
      },
      {
        title: 'Есть ли пробный период для различных планов?',
        description:
          "К сожалению, мы не предлагаем пробные периоды. Однако вы можете ознакомиться с нашей демо-версией.",
      },
      {
        title: 'Могу ли я переключаться между планами?',
        description:
          'Разумеется! Вы можете легко повысить или понизить свой план в любое время.',
      },
      {
        title: 'Какие способы оплаты вы принимаете?',
        description:
          'Мы принимаем основные кредитные карты и онлайн-способы оплаты для обеспечения удобства транзакций.',
      },
      {
        title: 'Есть ли скрытые платежи?',
        description:
          'Нет, стоимость подписки покрывает все функции, перечисленные в каждом плане. Никаких скрытых комиссий.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Готовы ускорить свои проекты?"
    subtitle="Присоединяйтесь к нашему сообществу довольных клиентов."
    actions={[
      {
        variant: 'primary',
        text: 'Начать сейчас',
        href: '/',
      },
    ]}
  />
</Layout>
