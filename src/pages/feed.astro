    // Get user posts from localStorage
    function getUserPosts() {
      const users = JSON.parse(localStorage.getItem('amantle_users') || '[]');
      const allUserPosts: any[] = [];
      users.forEach((user: any) => {
        if (user.posts && user.posts.length) {
          user.posts.forEach((post: any) => {
            allUserPosts.push({
              ...post,
              author: user.name,
              avatar: user.avatar || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.name)}&backgroundColor=515f74&textColor=ffffff`,
            });
          });
        }
      });
      return allUserPosts;
    }

    function createPostCard(post: any) {
      return `
        <div class="bloom-card-wrapper">
          <article class="post-card" data-post-id="${post.id}">
            ${post.image ? `<img class="post-card-image" src="${post.image}" alt="${post.title}" loading="lazy" />` : `
              <div class="post-card-image" style="display:flex;align-items:center;justify-content:center;">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#a8b3bb" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
              </div>
            `}
            <div class="post-card-body">
              <span class="post-card-category">${post.category || 'Заметка'}</span>
              <h3 class="post-card-title">${post.title}</h3>
              <p class="post-card-excerpt">${post.excerpt || post.content?.substring(0, 120) || ''}</p>
              <div class="post-card-footer">
                <div class="post-card-author">
                  <img class="author-avatar" src="${post.avatar}" alt="${post.author}" />
                  <div>
                    <div class="author-name">${post.author}</div>
                    <div class="post-card-date">${post.date || new Date(post.createdAt).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' })}</div>
                  </div>
                </div>
                <div class="post-card-actions">
                  <button class="post-action-btn like-btn" data-id="${post.id}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    <span>${post.likes ?? Math.floor(Math.random() * 50 + 5)}</span>
                  </button>
                  <button class="post-action-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    <span>${post.comments ?? Math.floor(Math.random() * 20 + 1)}</span>
                  </button>
                </div>
              </div>
            </div>
          </article>
        </div>
      `;
    }

    function renderPosts(filterText = '') {
      if (!grid) return;

      const userPosts = getUserPosts();
      let allPosts = [...userPosts, ...samplePosts];

      if (filterText) {
        const lower = filterText.toLowerCase();
        allPosts = allPosts.filter(
          (p) =>
            p.title.toLowerCase().includes(lower) ||
            (p.excerpt || '').toLowerCase().includes(lower) ||
            (p.category || '').toLowerCase().includes(lower) ||
            p.author.toLowerCase().includes(lower)
        );
      }

      if (allPosts.length === 0) {
        grid.innerHTML = '';
        emptyState?.classList.remove('hidden');
      } else {
        emptyState?.classList.add('hidden');
        grid.innerHTML = allPosts.map(createPostCard).join('');
      }
    }

    // Initial render
    renderPosts();

    // Search
    searchInput?.addEventListener('input', (e) => {
      const value = (e.target as HTMLInputElement).value;
      renderPosts(value);
    });

    // New post button
    newPostBtn?.addEventListener('click', () => {
      const currentUser = localStorage.getItem('amantle_current_user');
      if (!currentUser) {
        window.location.href = '/auth';
      } else {
        window.location.href = '/editor';
      }
    });

    // Like functionality
    grid?.addEventListener('click', (e) => {
      const likeBtn = (e.target as HTMLElement).closest('.like-btn');
      if (likeBtn) {
        e.stopPropagation();
        const countSpan = likeBtn.querySelector('span');
        if (countSpan) {
          const current = parseInt(countSpan.textContent || '0');
          const isLiked = likeBtn.classList.contains('liked');
          countSpan.textContent = String(isLiked ? current - 1 : current + 1);
          likeBtn.classList.toggle('liked');
          if (!isLiked) {
            likeBtn.querySelector('svg')?.setAttribute('fill', '#515f74');
            likeBtn.querySelector('svg')?.setAttribute('stroke', '#515f74');
          } else {
            likeBtn.querySelector('svg')?.setAttribute('fill', 'none');
            likeBtn.querySelector('svg')?.setAttribute('stroke', 'currentColor');
          }
        }
      }
    });
  });
</script>
