---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = {
  title: 'Лента — Amantle',
  description: 'Все посты и записи сообщества Amantle в одной ленте. Scroll to bloom.',
};
---

<Layout metadata={metadata}>
  <Header {...headerData} isSticky showToggleTheme />
  <main class="feed-page">
    <div class="feed-header">
      <div class="feed-header-content">
        <h1>Лента</h1>
        <p>Все посты сообщества</p>
      </div>
      <div class="feed-actions">
        <div class="feed-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input type="text" id="feed-search-input" placeholder="Поиск по постам..." />
        </div>
        <button class="new-post-btn" id="new-post-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          <span>Новый пост</span>
        </button>
      </div>
    </div>

    <!-- Scroll to bloom grid -->
    <div class="bloom-grid" id="bloom-grid">
      <!-- Posts will be inserted dynamically -->
    </div>

    <!-- Empty state -->
    <div class="empty-state hidden" id="empty-state">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
      <h3>Пока нет постов</h3>
      <p>Создайте первый пост, чтобы он появился в ленте</p>
    </div>
  </main>
  <Footer {...footerData} />
</Layout>

<style is:global>
  .feed-page {
    min-height: 100vh;
    background: #f7f9fc;
    padding-bottom: 4rem;
  }

  .feed-header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2.5rem 2rem 1.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .feed-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #29343a;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .feed-header p {
    color: #566168;
    font-size: 0.875rem;
    margin: 0.25rem 0 0;
  }

  .feed-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .feed-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: white;
    border: 1.5px solid #e1e9f0;
    border-radius: 12px;
    transition: all 0.25s;
    min-width: 240px;
  }

  .feed-search:focus-within {
    border-color: #515f74;
    box-shadow: 0 0 0 3px rgba(81, 95, 116, 0.1);
  }

  .feed-search svg {
    color: #a8b3bb;
    flex-shrink: 0;
  }

  .feed-search input {
    border: none;
    background: none;
    outline: none;
    font-size: 0.875rem;
    color: #29343a;
    font-family: inherit;
    width: 100%;
  }

  .feed-search input::placeholder {
    color: #a8b3bb;
  }

  .new-post-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, #515f74, #455367);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    font-family: inherit;
    white-space: nowrap;
  }

  .new-post-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(81, 95, 116, 0.25);
  }

  /* Scroll to Bloom Grid */
  .bloom-grid {
    --cols: 2;
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: 1.25rem;
    padding: 1rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    place-items: start;
  }

  @media (min-width: 720px) {
    .bloom-grid { --cols: 3; }
  }

  @media (min-width: 1024px) {
    .bloom-grid { --cols: 4; }
  }

  @media (min-width: 1440px) {
    .bloom-grid { --cols: 5; }
  }

  /* Bloom animation */
  @keyframes bloom-in {
    from {
      scale: 0.85;
      opacity: 0;
      rotate: calc(var(--bloom-side, 1) * (4deg * var(--bloom-amp, 1)));
    }
    to {
      scale: 1;
      opacity: 1;
      rotate: 0deg;
    }
  }

  .bloom-card-wrapper {
    display: grid;
    animation: bloom-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .bloom-card-wrapper {
        animation: bloom-in linear both;
        animation-timeline: view();
        animation-range: cover 0% contain 20%;
      }
    }
  }

  /* Bloom rotation origins per column position */
  .bloom-card-wrapper:nth-child(2n+1) {
    transform-origin: 25vw 100%;
    --bloom-side: -1;
  }
  .bloom-card-wrapper:nth-child(2n) {
    transform-origin: -25vw 100%;
    --bloom-side: 1;
  }

  @media (min-width: 720px) {
    .bloom-card-wrapper:nth-child(3n+1) {
      transform-origin: 40vw 100%;
      --bloom-side: -1;
      --bloom-amp: 1.5;
    }
    .bloom-card-wrapper:nth-child(3n+2) {
      transform-origin: 0vw 100%;
      --bloom-side: -1;
    }
    .bloom-card-wrapper:nth-child(3n) {
      transform-origin: -40vw 100%;
      --bloom-side: 1;
      --bloom-amp: 1.5;
    }
  }

  @media (min-width: 1024px) {
    .bloom-card-wrapper:nth-child(4n+1) {
      transform-origin: 50vw 100%;
      --bloom-side: -1;
      --bloom-amp: 2;
    }
    .bloom-card-wrapper:nth-child(4n+2) {
      transform-origin: 25vw 100%;
      --bloom-side: -1;
    }
    .bloom-card-wrapper:nth-child(4n+3) {
      transform-origin: -25vw 100%;
      --bloom-side: 1;
    }
    .bloom-card-wrapper:nth-child(4n) {
      transform-origin: -50vw 100%;
      --bloom-side: 1;
      --bloom-amp: 2;
    }
  }

  /* Post Card */
  .post-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(41, 52, 58, 0.06);
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    cursor: pointer;
    position: relative;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(41, 52, 58, 0.12);
  }

  .post-card-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    background: linear-gradient(135deg, #e1e9f0, #d9e4ec);
  }

  .post-card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .post-card-category {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #515f74;
    background: #f0f4f8;
    padding: 4px 10px;
    border-radius: 6px;
    margin-bottom: 0.625rem;
  }

  .post-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #29343a;
    line-height: 1.35;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-excerpt {
    font-size: 0.8125rem;
    color: #566168;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .post-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid #f0f4f8;
  }

  .post-card-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .author-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    background: #e1e9f0;
  }

  .author-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: #29343a;
  }

  .post-card-date {
    font-size: 0.6875rem;
    color: #a8b3bb;
  }

  .post-card-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .post-action-btn {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    color: #a8b3bb;
    font-size: 0.75rem;
    cursor: pointer;
    transition: color 0.2s;
    padding: 0;
    font-family: inherit;
  }

  .post-action-btn:hover {
    color: #515f74;
  }

  .post-action-btn svg {
    width: 16px;
    height: 16px;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    max-width: 400px;
    margin: 0 auto;
  }

  .empty-state.hidden {
    display: none;
  }

  .empty-state h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #29343a;
    margin: 1.5rem 0 0.5rem;
  }

  .empty-state p {
    color: #566168;
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .feed-header {
      padding: 1.5rem 1rem 1rem;
    }

    .bloom-grid {
      padding: 1rem;
      --cols: 1 !important;
    }

    .feed-actions {
      width: 100%;
      flex-direction: column;
    }

    .feed-search {
      width: 100%;
      min-width: unset;
    }

    .new-post-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

